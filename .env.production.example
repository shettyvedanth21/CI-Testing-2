# GHCR image resolution for production deployments
GHCR_OWNER_LOWER=cittagent
GHCR_REPO_LOWER=shivex-main-1
APP_IMAGE_TAG=sha-<commit-sha>

# Optional per-service image tag overrides
DEVICE_SERVICE_IMAGE_TAG=
ENERGY_SERVICE_IMAGE_TAG=
DATA_SERVICE_IMAGE_TAG=
RULE_ENGINE_SERVICE_IMAGE_TAG=
ANALYTICS_API_IMAGE_TAG=
ANALYTICS_WORKER_IMAGE_TAG=
DATA_EXPORT_SERVICE_IMAGE_TAG=
REPORTING_SERVICE_IMAGE_TAG=
WASTE_ANALYSIS_SERVICE_IMAGE_TAG=
COPILOT_SERVICE_IMAGE_TAG=
AUTH_SERVICE_IMAGE_TAG=
UI_WEB_IMAGE_TAG=

# Core production runtime settings
ENVIRONMENT=production
DATABASE_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
JWT_SECRET_KEY=
INTERNAL_SERVICE_SHARED_SECRET=
AUTH_SERVICE_URL=http://auth-service:8090

# AWS / object storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
AWS_ENDPOINT_URL_S3=
S3_BUCKET=energy-platform-datasets
S3_BUCKET_NAME=energy-platform-datasets
MINIO_BUCKET=energy-platform-datasets
MINIO_EXTERNAL_URL=
MINIO_ENDPOINT=
SNAPSHOT_STORAGE_BACKEND=auto
SNAPSHOT_MINIO_BUCKET=dashboard-snapshots
SNAPSHOT_MINIO_ENDPOINT=
SNAPSHOT_MINIO_ACCESS_KEY=
SNAPSHOT_MINIO_SECRET_KEY=
SNAPSHOT_MINIO_SECURE=false

# Frontend / URLs
FRONTEND_BASE_URL=https://shivex.ai
NEXT_PUBLIC_API_URL=https://shivex.ai
EXTERNAL_URL=
DATA_ALLOWED_ORIGINS=
ALERTMANAGER_EXTERNAL_URL=

# Host nginx upstream bindings.
# Bind API services to loopback only; nginx on the host proxies public traffic.
DEVICE_SERVICE_HOST_BIND=127.0.0.1
DEVICE_SERVICE_HOST_PORT=8000
DATA_SERVICE_HOST_BIND=127.0.0.1
DATA_SERVICE_HOST_PORT=8081
RULE_ENGINE_SERVICE_HOST_BIND=127.0.0.1
RULE_ENGINE_SERVICE_HOST_PORT=8002
ANALYTICS_SERVICE_HOST_BIND=127.0.0.1
ANALYTICS_SERVICE_HOST_PORT=8003
REPORTING_SERVICE_HOST_BIND=127.0.0.1
REPORTING_SERVICE_HOST_PORT=8085
WASTE_ANALYSIS_SERVICE_HOST_BIND=127.0.0.1
WASTE_ANALYSIS_SERVICE_HOST_PORT=8087
COPILOT_SERVICE_HOST_BIND=127.0.0.1
COPILOT_SERVICE_HOST_PORT=8007

# SMTP / alerting
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=
ALERT_SMTP_TO=

# MQTT / broker
MQTT_USERNAME=
MQTT_PASSWORD=
EMQX_DASHBOARD_USERNAME=
EMQX_DASHBOARD_PASSWORD=
EMQX_AUTH_MYSQL_PASSWORD=
