{
  "name": "ui-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run lint:hooks && next build",
    "typecheck": "tsc --noEmit",
    "start": "node server.mjs",
    "lint": "eslint",
    "lint:hooks": "eslint --no-config-lookup --ext .ts,.tsx --parser @typescript-eslint/parser --parser-options '{\"ecmaVersion\":\"latest\",\"sourceType\":\"module\",\"ecmaFeatures\":{\"jsx\":true}}' --plugin react-hooks --rule 'react-hooks/rules-of-hooks:error' --report-unused-disable-directives-severity off --max-warnings=0 app",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}
