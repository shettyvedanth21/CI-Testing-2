K6_ROUTE_MODE=direct

K6_AUTH_BASE_URL=http://localhost:8090
K6_DEVICE_BASE_URL=http://localhost:8000
K6_ANALYTICS_BASE_URL=http://localhost:8003
K6_REPORTING_BASE_URL=http://localhost:8085
K6_WASTE_BASE_URL=http://localhost:8087
K6_RULES_BASE_URL=http://localhost:8002

K6_LOGIN_EMAIL=
K6_LOGIN_PASSWORD=

# Prefer setting this explicitly for repeatable multi-tenant runs.
K6_TENANT_ID=
K6_PLANT_ID=

# Optional device overrides. If blank, the toolkit discovers devices from device-service.
K6_DEVICE_IDS=
K6_SELECTED_DEVICE_COUNT=3

K6_SCENARIO=mixed
K6_DURATION=10m
K6_VUS=4
K6_RATE=
K6_TIME_UNIT=1s
K6_PREALLOCATED_VUS=4
K6_MAX_VUS=12
K6_EXECUTOR=constant-vus

K6_ANALYTICS_TYPE=anomaly
K6_ANALYTICS_MODEL=
K6_REPORT_DAYS=7
K6_WASTE_GRANULARITY=daily

K6_HTTP_TIMEOUT=60s
K6_STRICT_FEATURE_PREFLIGHT=true
K6_HTTP_REQ_FAILED_THRESHOLD="rate<0.05"
K6_HTTP_REQ_DURATION_P95_THRESHOLD="p(95)<2500"
K6_HTTP_REQ_DURATION_P99_THRESHOLD="p(99)<5000"

K6_POLL_ATTEMPTS=10
K6_POLL_INTERVAL_MS=3000
K6_THINK_TIME_MS=1000
K6_FETCH_ARTIFACTS=false

K6_MIX_ANALYTICS_WEIGHT=3
K6_MIX_REPORTS_WEIGHT=3
K6_MIX_WASTE_WEIGHT=2
K6_MIX_RULES_WEIGHT=2
